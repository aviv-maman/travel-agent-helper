# Neon Postgres connection string (Project → Connection Details → "Pooled connection")
# Copy this file to .env.local and fill in the value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Base URL of the auth backend (the Python service that runs Google/Microsoft
# OAuth). Leave unset until it exists — the "Continue with…" buttons only render
# when this is set. See docs/auth-backend-contract.md.
# AUTH_BACKEND_URL="https://your-app.example.com/api"

# Fetch proxy for news sources whose WAF blocks our production (datacenter) IP —
# israelhayom, c14, maariv (marked `proxied` in lib/news.ts). Must point at a small
# service on an allowed IP that refetches ?url=<encoded> and returns the body. Leave
# UNSET locally: those sources are then fetched directly (works from a residential
# IP). See docs/news-fetch-proxy.md.
# NEWS_FETCH_PROXY="https://your-proxy.example.com/fetch"

# Base URL of the Python backend (travel-agent-backend) that owns the AI quote
# assistant — the encrypted key store + POST /ai/chat. Drives two things:
#   1. server-side reads/writes proxy there (lib/ai/backend.ts), and
#   2. next.config.ts adds the same-origin rewrite /api/ai/* -> BACKEND_URL/ai/*
#      so the browser's chat stream flows with the session cookie (no CORS).
# Rewrites resolve at BUILD time — set this in the Vercel env, then redeploy.
# Locally: http://localhost:8000 (with `uvicorn main:app --port 8000` running).
# When unset, the AI settings/chat fall back to mock mode.
# BACKEND_URL="http://localhost:8000"

# Force the client-side chat mock even when a backend exists (demo mode).
# Set to 1 only when BACKEND_URL is unset; remove it once the backend is wired.
# NEXT_PUBLIC_AI_MOCK=1
