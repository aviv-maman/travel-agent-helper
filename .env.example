# Neon Postgres connection string (Project → Connection Details → "Pooled connection")
# Copy this file to .env.local and fill in the value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# OAuth "Continue with Google" — the buttons only render when this is set, and it's
# the link prefix for /auth/{provider}/start. Set it to the same-origin API prefix
# "/api" so links become /api/auth/google/start, which next.config.ts rewrites to
# BACKEND_URL/auth/*. The backend also needs GOOGLE_CLIENT_ID/SECRET + PUBLIC_APP_URL.
# See docs/auth-backend-contract.md.
# AUTH_BACKEND_URL="/api"
# Providers actually wired (comma list). Google is built; add microsoft once it is.
# AUTH_PROVIDERS="google"

# Google Places API (New) key — used only by scripts/enrich-hotels-places.ts to
# fill the hotels' Google rating/address/website/photo columns (DB-managed; the
# backend's weekly /cron/places refreshes ratings with its own copy of the key).
# GOOGLE_PLACES_API_KEY="AIza..."

# Apify API token — used only by scripts/enrich-hotels-rooms.ts (one-time paid
# run, ~$0.01/hotel) to fill each hotel's room list from Booking.com. Script-only;
# never needed at runtime or on any deploy. Token: apify.com console → Settings →
# API & Integrations.
# APIFY_TOKEN="apify_api_..."

# Fetch proxy for news sources whose WAF blocks our production (datacenter) IP —
# israelhayom, c14, maariv (marked `proxied` in lib/news.ts). Must point at a small
# service on an allowed IP that refetches ?url=<encoded> and returns the body. Leave
# UNSET locally: those sources are then fetched directly (works from a residential
# IP). See docs/news-fetch-proxy.md.
# NEWS_FETCH_PROXY="https://your-proxy.example.com/fetch"

# Base URL of the Python backend (travel-agent-backend) that owns the AI quote
# assistant — the encrypted key store + POST /ai/chat. Drives two things:
#   1. server-side reads/writes proxy there (lib/ai/backend.ts), and
#   2. next.config.ts adds the same-origin rewrite /api/ai/* -> BACKEND_URL/ai/*
#      so the browser's chat stream flows with the session cookie (no CORS).
# Rewrites resolve at BUILD time — set this in the Vercel env, then redeploy.
# Locally: http://localhost:8000 (with `uvicorn main:app --port 8000` running).
# When unset, the AI settings/chat fall back to mock mode.
# BACKEND_URL="http://localhost:8000"

# Shared secret for server-to-server calls to the backend that use X-Service-Key
# (currently POST /email/send, for password reset + email verification). MUST equal
# the backend's SERVICE_KEY. Until it (and the backend's Resend creds) are set, those
# emails silently don't send and the flows show a neutral message. Keep it server-side.
# SERVICE_KEY="<same value as the backend's SERVICE_KEY>"

# Avatar uploads (docs/file-upload-contract.md). The avatar "Change photo" UI only
# renders when FILE_UPLOAD_URL is set — point it at the same-origin prefix "/api/files"
# (next.config.ts rewrites it to BACKEND_URL/files/*). SUPABASE_PUBLIC_BASE_URL must match
# the backend's (the public bucket's base), so the persist action can validate the uploaded
# URL. Both unset by default.
# FILE_UPLOAD_URL="/api/files"
# SUPABASE_PUBLIC_BASE_URL="https://<project-ref>.supabase.co/storage/v1/object/public/avatars"

# Force the client-side chat mock even when a backend exists (demo mode).
# Set to 1 only when BACKEND_URL is unset; remove it once the backend is wired.
# NEXT_PUBLIC_AI_MOCK=1
