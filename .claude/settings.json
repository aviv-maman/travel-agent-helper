{
  "permissions": {
    "allow": [
      "Bash(echo \"exit code: $?\")",
      "PowerShell(if \\($?\\) { \"TS OK\" })",
      "PowerShell(npx --no-install tsc -p tsconfig.json --noEmit)",
      "Bash(node_modules/.bin/tsc.exe --noEmit)",
      "PowerShell(npx -p typescript tsc --noEmit 2>&1)",
      "Bash(echo \"exit:$?\")",
      "WebFetch(domain:github.com)",
      "Bash(node -e ' *)",
      "PowerShell(npx tsc --noEmit -p tsconfig.json)",
      "PowerShell(if \\(Test-Path package.json\\) { \\(Get-Content package.json -Raw | ConvertFrom-Json\\).scripts })",
      "Bash(git mv *)",
      "PowerShell(npx tsc --noEmit -p tsconfig.json 2>&1)",
      "PowerShell(if \\(Test-Path package.json\\) { \\(Get-Content package.json -Raw | ConvertFrom-Json\\).scripts | ConvertTo-Json })",
      "PowerShell(npm run typecheck 2>&1)"
    ]
  }
}
