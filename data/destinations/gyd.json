  "name": {
    "he": "באקו",
    "en": "Baku"
  },
  "country": {
    "he": "אזרבייג'ן",
    "en": "Azerbaijan"
  },
  "countryCode": "AZ",
  "info": {
    "about": {
      "he": "באקו יושבת על מפרץ הים הכספי: העיר העתיקה (איצ'רי שהר) מוקפת חומה ומוכרת כאתר מורשת עולמית של אונסק\"ו, ומעליה מתנשאים מגדלי הלהבה. רוב מלונות התיירים ברובעי סבאיל ונסימי — במרחק הליכה מהעיר העתיקה, מכיכר המזרקות ומטיילת הים (הבולוואר).",
      "en": "Baku sits on a bay of the Caspian: the walled Old City (Icherisheher) is a UNESCO World Heritage site, with the Flame Towers rising above it. Most tourist hotels are in the Sabail and Nasimi districts — walking distance from the Old City, Fountains Square and the seaside boulevard."
    },
    "attractions": {
      "he": "🏛 אתרים מרכזיים: העיר העתיקה (איצ'רי שהר) · מגדל הבתולה · ארמון השירוואנשאהים · מגדלי הלהבה · מרכז היידר אלייב · טיילת הים (בולוואר)",
      "en": "🏛 Main sights: Old City (Icherisheher) · Maiden Tower · Shirvanshahs' Palace · Flame Towers · Heydar Aliyev Center · Seaside Boulevard"
    },
    "currencyNote": {
      "he": "המטבע המקומי: מאנאט אזרבייג'ני (AZN) · הערכת שער: 1 מאנאט ≈ ₪1.77",
      "en": "Local currency: Azerbaijani manat (AZN) · Approx. rate: 1 manat ≈ ₪1.77"
    },
    "airport": {
      "title": {
        "he": "✈ שדה התעופה — GYD (Heydar Aliyev)",
        "en": "✈ Airport — GYD (Heydar Aliyev)"
      },
      "note": {
        "he": "מרחק: ~25 ק\"מ ממרכז העיר · זמן נסיעה: 30–40 דקות",
        "en": "Distance: ~25 km from the city center · Travel time: 30–40 minutes"
      }
    },
    "transport": [
      {
        "icon": "🚌",
        "mode": {
          "he": "אווירו-אקספרס H1",
          "en": "Aeroexpress H1"
        },
        "detail": {
